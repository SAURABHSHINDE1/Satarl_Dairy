# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=system
DB_NAME=satral_dairy_test

# JWT Configuration
JWT_SECRET=satral-dairy-erp-secret-key-2024-production-ready
JWT_REFRESH_SECRET=satral-dairy-erp-refresh-key-2024-production-ready
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Security
BCRYPT_ROUNDS=10
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# Session
SESSION_TIMEOUT=30

# CORS
CORS_ORIGIN=http://localhost:5173
